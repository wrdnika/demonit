SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_ENV=development

# PostgreSQL DSN (GORM format)
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=demonit port=5432 sslmode=disable TimeZone=UTC

# Connection pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=2m

# Deadman's switch
WORKER_INTERVAL=30s
OFFLINE_TIMEOUT=30s

# Auth — NOT full login. Two shared secrets:
# DEVICE_API_KEY  → IoT agents on POST /api/v1/heartbeat  (header: X-Device-API-Key)
# ADMIN_API_KEY   → dashboard register on POST /api/v1/devices (header: X-Admin-API-Key)
DEVICE_API_KEY=dev-device-key-change-me
ADMIN_API_KEY=dev-admin-key-change-me

# Browser origins allowed to call the API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000
