# Copy to .env and adjust for local Docker Compose.
# docker compose automatically loads .env from this directory.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=demonit
# Change to 5433 if a local Postgres already uses 5432
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000

# production → SQL from migrations/ (initdb). development → AutoMigrate also OK.
APP_ENV=production

DEVICE_API_KEY=dev-device-key-change-me
ADMIN_API_KEY=dev-admin-key-change-me

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Browser → host-mapped API. Agents also use this URL.
NUXT_PUBLIC_API_BASE=http://localhost:8080
NUXT_PUBLIC_POLL_INTERVAL_MS=15000

WORKER_INTERVAL=30s
OFFLINE_TIMEOUT=30s
